# ---- ProcureFlow environment template ----
# Copy to `.env` and fill in real values. `.env` is never committed.

# --- App ---
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=procureflow
POSTGRES_USER=procureflow
POSTGRES_PASSWORD=
# Full connection string (used by Drizzle)
DATABASE_URL=postgres://procureflow:@localhost:5432/procureflow

# --- Redis (cache / BullMQ queues) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=

# --- Email (asynchronous notifications) ---
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@procureflow.local
