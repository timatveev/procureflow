# ---- ProcureFlow environment template ----
# Copy to `.env` and adjust. `.env` is never committed.
#
# Hosts default to Docker Compose service names (`db`, `redis`, `mailpit`) because the
# containerized API is the primary consumer. Host-side tools (DB GUI, ad-hoc psql) reach
# the same services via the published ports on `localhost`.
#
# NOTE: DATABASE_URL / REDIS_URL / SMTP_HOST below resolve only INSIDE the compose network.
# Tools run on the host (e.g. drizzle-kit reading DATABASE_URL) must override the host to
# `localhost` + the published port, or be run inside the network.

# --- App ---
NODE_ENV=development
# API_PORT is the HOST port; the API always listens on a fixed 3000 inside its container.
API_PORT=3000
WEB_PORT=5173

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=procureflow
POSTGRES_USER=procureflow
# Local dev only — NOT a secret. Real environments inject a real password.
POSTGRES_PASSWORD=procureflow_dev
# Full connection string (used by Drizzle)
DATABASE_URL=postgres://procureflow:procureflow_dev@db:5432/procureflow

# --- Redis (cache / BullMQ queues) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=

# --- Email (asynchronous notifications) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@procureflow.local
# Mailpit web UI (host access): http://localhost:${MAILPIT_UI_PORT}
MAILPIT_UI_PORT=8025
