# Dependencies
node_modules/
.pnp.*
.yarn/*

# Build output
dist/
build/
out/
*.tsbuildinfo
.vite/

# Test / coverage
coverage/
*.lcov

# Env & secrets
.env
.env.*
!.env.dist
*.pem

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Claude Code — local agent settings are not tracked (the harness rewrites them)
.claude/settings.json
.claude/settings.local.json

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
*.swp
*Zone.Identifier

# Bun: ignore the legacy binary lockfile only. The text `bun.lock` (e.g. apps/api) is tracked.
bun.lockb

# Drizzle local artifacts
drizzle/.cache/
