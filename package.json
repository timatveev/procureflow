{
  "name": "procureflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "B2B Enterprise Procurement Portal — Specs Before Code training project",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "docker compose up",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
